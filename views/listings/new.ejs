<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row">
        <div class="col-8 offset-2"> <br> 
            <h3>Create Listing</h3> <br>
            <form method="post" action="/listings/new" novalidate class="needs-validation" enctype="multipart/form-data">
                <div>
                    <label for="title" class="form-label">Title:</label>
                    <input type="text" placeholder="Input Title" id="title" name="listing[title]" class="form-control" required>
                    <div class="valid-feedback">Title looks good!</div>
                </div> <br> <br>
                
                <div>
                    <label for="description" class="form-label">Input Description: </label>
                    <input type="text" placeholder="Input Description" id="description" class="form-control"  name="listing[description]" required> 
                    <div class="invalid-feedback">Please enter a short description</div>
                </div><br><br>
                
                <!-- <div>
                    <label for="image" class="form-label">Input Image URL: </label>
                    <input type="text" placeholder="Input Image" class="form-control" id="image" name="listing[image][url]" > 
                </div><br><br> -->

                <div>
                    <label for="image" class="form-label">Upload Listing Image: </label>
                    <input type="file" class="form-control" id="image" name="listing[image]" > 
                </div><br><br>
                
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Input Price: </label>
                        <input type="number" placeholder="Input Price" class="form-control"  id="price" name="listing[price]" required min="0">
                        <div class="invalid-feedback">Price should be valid</div>
                    </div>
                
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Input Country: </label>
                        <input type="text" placeholder="Input Country" class="form-control"  id="country" name="listing[country]" required>
                        <div class="invalid-feedback">Country name should be valid</div>
                    </div>
                </div><br><br>
                
                <div>
                    <label for="location" class="form-label">Input location: </label>
                    <input type="text" placeholder="Input Location" class="form-control"  id="location" name="listing[location]" required> 
                    <div class="invalid-feedback">Location should be valid</div>
                </div><br><br>
                
                <br>
                <button class="btn btn-dark add-btn">submit</button> 
                <br><br>
            </form>
        </div>
    </div>
</body>