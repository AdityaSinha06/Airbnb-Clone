<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row">
        <div class="col-8 offset-2"> <br>
            <h3>Listing Details: </h3> <br>
            
            <div class="card show-card">
                <img src="<%=listing.image.url%>" class="card-img-top show-img" > <br>
                <div class="card-body">
                    <p class="card-text">
                        <b><%=listing.title%></b> <br>
                        <%=listing.description%> <br>
                        &#8377;<%=listing.price.toLocaleString("en-IN")%> <br>
                        <%=listing.location%> <br>
                        <%=listing.country%>
                    </p>
                </div>
            </div>

            <div class="btns">
                <a href="/listing/<%=listing._id%>/edit" class="btn btn-dark col-1  edit-btn">Edit</a>
                <form method="post" action="/listing/<%=listing._id%>/delete?_method=delete">
                    <button class="btn btn-dark offset-4">Delete</button>
                </form>
            </div>
        </div>
    </div>
</body>